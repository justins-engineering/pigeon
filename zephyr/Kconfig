menuconfig PIGEON
  bool "Pigeon Client Platform Library"
  default n
  help
    Enable the client-side modeling and synchronization logic
    for linking physical assets to the PidgeIoT edge core.

if PIGEON

choice PIGEON_CONNECTOR_TYPE
  prompt "Default Network Serialization Connector"
  default PIGEON_CONNECTOR_COAP

config PIGEON_CONNECTOR_COAP
  bool "CoAP over NIDD/Cellular"
  select COAP
  select JSON_LIBRARY
  help
    Serialize device shadow deltas into minimal byte blocks optimized for
    constrained cellular paths. Speaks CoAP-over-TLS/TCP (RFC 8323,
    coaps+tcp://) rather than the usual CoAP-over-DTLS/UDP -- this device
    stack has no UDP support yet, see pigeon_coap_config in pigeon.h.

config PIGEON_CONNECTOR_HTTPS
  bool "HTTPS REST API"
  select HTTP_CLIENT
  select JSON_LIBRARY
  help
    Standard TLS socket interface for line-powered gateways.

endchoice

if PIGEON_CONNECTOR_COAP

config PIGEON_COAP_SEC_TAG
  int "TLS sec_tag for the Pigeon CoAP connector"
  default 1
  help
    Security tag under which credentials for CONFIG_PIGEON_ENDPOINT are
    provisioned: PSK identity/secret (tls_credential_add, registered
    automatically by this library from pigeon_coap_config when the app
    supplies them via pigeon_init()) or, if the app didn't supply PSK
    fields, a CA cert the app provisioned itself -- same model as
    CONFIG_PIGEON_HTTPS_SEC_TAG. Must match whatever the application
    provisioned under this tag.

endif # PIGEON_CONNECTOR_COAP

if PIGEON_CONNECTOR_HTTPS

config PIGEON_HTTPS_SEC_TAG
  int "TLS sec_tag for the Pigeon HTTPS connector"
  default 1
  help
    Security tag under which the CA cert for CONFIG_PIGEON_ENDPOINT is
    provisioned (via modem_key_mgmt on nRF91 offloaded sockets, or
    tls_credential_add elsewhere). Must match whatever the application
    provisioned its cert(s) under -- this library does not provision
    anything itself, only opens sockets against this tag.

endif # PIGEON_CONNECTOR_HTTPS

config PIGEON_LOG_UPLOAD
  bool "Remote log upload (Zephyr dictionary-based logging)"
  default n
  depends on PIGEON_CONNECTOR_HTTPS
  select LOG_DICTIONARY_SUPPORT
  help
    Capture this device's log output via Zephyr's dictionary-based
    logging (CONFIG_LOG_DICTIONARY_SUPPORT -- format strings are
    stripped from the firmware image and never sent over the air,
    only a source id, level, timestamp, and packed arguments per
    record, which is the low-data win) into a bounded ring buffer,
    and flush it in batches as a raw binary POST to
    <CONFIG_PIGEON_ENDPOINT>/logs, device-authenticated the same way
    as the telemetry/shadow reports in pigeon_https.c. Off by
    default -- existing samples build unchanged, and enabling it
    changes the build's log_dictionary.json requirement for decoding
    (see pigeon-examples' README for the host-side decode flow).
    HTTPS connector only; the CoAP connector has no equivalent
    transport for this yet.

if PIGEON_LOG_UPLOAD

config PIGEON_LOG_UPLOAD_BUF_SIZE
  int "Pigeon log upload ring buffer size (bytes)"
  default 2048
  help
    Bounded ring buffer holding dictionary-mode log records not yet
    uploaded. Once full, newly produced records are dropped rather
    than blocking the caller or growing without bound -- see
    pigeon_log_backend.c.

config PIGEON_LOG_UPLOAD_BATCH_SIZE
  int "Pigeon log upload batch flush threshold (bytes)"
  default 512
  range 1 PIGEON_LOG_UPLOAD_BUF_SIZE
  help
    Once this many bytes have accumulated in the ring buffer, a
    flush is triggered immediately rather than waiting for the
    max-interval timeout below.

config PIGEON_LOG_UPLOAD_MAX_INTERVAL_MS
  int "Pigeon log upload max flush interval (ms)"
  default 60000
  help
    Upper bound on how long a partially-filled batch waits before
    being flushed anyway, so low log-volume devices still ship
    records instead of holding them indefinitely below the
    batch-size threshold above.

endif # PIGEON_LOG_UPLOAD

endif # PIGEON

# Not nested under "if PIGEON": pigeon_core.c (which reads these) is compiled
# unconditionally by CMakeLists.txt regardless of CONFIG_PIGEON, so they must
# always have a value (an unsatisfied "if PIGEON" dependency would otherwise
# drop the CONFIG_PIGEON_* macro from autoconf.h entirely).
config PIGEON_ENDPOINT
  string "Pigeon Backend Endpoint"
  help
    URL of the PidgeIoT edge endpoint this device connects to: an
    https:// REST URL for CONFIG_PIGEON_CONNECTOR_HTTPS, or a
    coaps+tcp:// (RFC 8323 CoAP-over-TLS/TCP) host for
    CONFIG_PIGEON_CONNECTOR_COAP, since this device stack has no UDP
    support yet. Mirrors dovecote's build_http_endpoint output for HTTPS
    (e.g. https://api.pidgeiot.com/device/pigeons/<device_id>) and
    build_coap_endpoint's coaps+tcp:// output for CoAP -- though dovecote
    has no actual CoAP listener yet, only the endpoint string.

config PIGEON_TOKEN
  string "Pigeon Device Auth Token"
  help
    The opaque per-pigeon bearer credential issued by the backend (see
    dovecote's mint_device_credential/get_shadow_device -- a compact binary
    token verified against this pigeon's own stored public key, not a JWT),
    with no "Bearer " prefix -- the HTTPS connector adds that itself when
    building the Authorization header. Returned once at provisioning (or
    re-minted, invalidating the previous token, via a token/refresh call);
    override this per build (e.g. via a board/app Kconfig fragment) rather
    than committing a real token here.

config PIGEON_LOG_LEVEL
  int "Pigeon Library Log Level"
  default 3
  range 0 4
  help
    0: None, 1: Error, 2: Warning, 3: Info, 4: Debug

menuconfig PIGEON
  bool "Pigeon Client Platform Library"
  default n
  help
    Enable the client-side modeling and synchronization logic
    for linking physical assets to the PidgeIoT edge core.

if PIGEON

choice PIGEON_CONNECTOR_TYPE
  prompt "Default Network Serialization Connector"
  default PIGEON_CONNECTOR_COAP

config PIGEON_CONNECTOR_COAP
  bool "CoAP over NIDD/Cellular"
  select COAP
  select JSON_LIBRARY
  help
    Serialize device shadow deltas into minimal byte blocks optimized for
    constrained cellular paths. Speaks CoAP-over-TLS/TCP (RFC 8323,
    coaps+tcp://) rather than the usual CoAP-over-DTLS/UDP -- this device
    stack has no UDP support yet, see pigeon_coap_config in pigeon.h.

config PIGEON_CONNECTOR_HTTPS
  bool "HTTPS REST API"
  select HTTP_CLIENT
  select JSON_LIBRARY
  help
    Standard TLS socket interface for line-powered gateways.

endchoice

if PIGEON_CONNECTOR_COAP

config PIGEON_COAP_SEC_TAG
  int "TLS sec_tag for the Pigeon CoAP connector"
  default 1
  help
    Security tag under which credentials for CONFIG_PIGEON_ENDPOINT are
    provisioned: PSK identity/secret (tls_credential_add, registered
    automatically by this library from pigeon_coap_config when the app
    supplies them via pigeon_init()) or, if the app didn't supply PSK
    fields, a CA cert the app provisioned itself -- same model as
    CONFIG_PIGEON_HTTPS_SEC_TAG. Must match whatever the application
    provisioned under this tag.

endif # PIGEON_CONNECTOR_COAP

if PIGEON_CONNECTOR_HTTPS

config PIGEON_HTTPS_SEC_TAG
  int "TLS sec_tag for the Pigeon HTTPS connector"
  default 1
  help
    Security tag under which the CA cert for CONFIG_PIGEON_ENDPOINT is
    provisioned (via modem_key_mgmt on nRF91 offloaded sockets, or
    tls_credential_add elsewhere). Must match whatever the application
    provisioned its cert(s) under -- this library does not provision
    anything itself, only opens sockets against this tag.

endif # PIGEON_CONNECTOR_HTTPS

config PIGEON_LOG_UPLOAD
  bool "Remote log upload (Zephyr dictionary-based logging)"
  default n
  depends on PIGEON_CONNECTOR_HTTPS
  select LOG_DICTIONARY_SUPPORT
  help
    Capture this device's log output via Zephyr's dictionary-based
    logging (CONFIG_LOG_DICTIONARY_SUPPORT -- format strings are
    stripped from the firmware image and never sent over the air,
    only a source id, level, timestamp, and packed arguments per
    record, which is the low-data win) into a bounded ring buffer,
    and flush it in batches as a raw binary POST to
    <CONFIG_PIGEON_ENDPOINT>/logs, device-authenticated the same way
    as the telemetry/shadow reports in pigeon_https.c. Off by
    default -- existing samples build unchanged, and enabling it
    changes the build's log_dictionary.json requirement for decoding
    (see pigeon-examples' README for the host-side decode flow).
    HTTPS connector only; the CoAP connector has no equivalent
    transport for this yet.

if PIGEON_LOG_UPLOAD

config PIGEON_LOG_UPLOAD_BUF_SIZE
  int "Pigeon log upload ring buffer size (bytes)"
  default 2048
  help
    Bounded ring buffer holding dictionary-mode log records not yet
    uploaded. Once full, newly produced records are dropped rather
    than blocking the caller or growing without bound -- see
    pigeon_log_backend.c.

config PIGEON_LOG_UPLOAD_BATCH_SIZE
  int "Pigeon log upload batch flush threshold (bytes)"
  default 512
  range 1 PIGEON_LOG_UPLOAD_BUF_SIZE
  help
    Once this many bytes have accumulated in the ring buffer, a
    flush is triggered immediately rather than waiting for the
    max-interval timeout below.

config PIGEON_LOG_UPLOAD_MAX_INTERVAL_MS
  int "Pigeon log upload max flush interval (ms)"
  default 60000
  help
    Upper bound on how long a partially-filled batch waits before
    being flushed anyway, so low log-volume devices still ship
    records instead of holding them indefinitely below the
    batch-size threshold above.

endif # PIGEON_LOG_UPLOAD

config PIGEON_FOTA
  bool "Firmware-over-the-air (FOTA) updates via MCUboot"
  default n
  depends on PIGEON_CONNECTOR_HTTPS
  depends on BOOTLOADER_MCUBOOT
  depends on IMG_MANAGER
  select DFU_TARGET
  select DFU_TARGET_MCUBOOT
  select PSA_CRYPTO
  select PSA_WANT_ALG_SHA_256
  help
    Chunked HTTP Range-GET download of the firmware image named in the
    shadow's target_config "firmware" key (see capsules/dovecote's
    shadow-driven FOTA route) straight into MCUboot's secondary slot
    via Zephyr's dfu_target/flash_img as it streams -- the image
    (up to ~1-2MB) is never held whole in RAM. Verifies the downloaded
    byte count and a streamed sha256 against the shadow-declared
    size/sha256 before scheduling a one-time test-swap
    (dfu_target_schedule_update, equivalent to
    boot_request_upgrade(BOOT_UPGRADE_TEST)). Does not reboot itself --
    the caller must gracefully tear down its own connectivity (e.g.
    lte_lc_power_off()/lte_disconnect()) and call sys_reboot() once
    pigeon_fota_apply() returns 0, same convention as the existing
    shadow "reboot": true command. Off by default -- existing samples
    build unchanged, and this can only be turned on for an application
    already built under sysbuild with MCUboot (CONFIG_BOOTLOADER_MCUBOOT,
    CONFIG_IMG_MANAGER -- see https_init's sysbuild.conf). HTTPS
    connector only; the CoAP connector has no download transport for
    this yet.

    MCUboot's own image signature check is the security boundary for
    firmware authenticity here (this library's sha256 check is only an
    integrity check against transport/flash corruption, not a
    signature) -- production deployments must sign with a real key, not
    NCS's dev key.

if PIGEON_FOTA

config PIGEON_FOTA_CHUNK_SIZE
  int "FOTA download chunk size (bytes)"
  default 2048
  help
    Size of each Range-GET request issued against
    <CONFIG_PIGEON_ENDPOINT>/firmware, and of the matching static
    receive/staging buffers this allocates. Each chunk is written
    straight to flash as it arrives (see pigeon_fota_apply() in
    pigeon_fota.c) -- the full image is never buffered whole in RAM,
    only this window of it.

config PIGEON_FOTA_CURRENT_VERSION
  string "Currently running firmware version string"
  help
    Compared byte-for-byte against the shadow target_config's
    firmware.version field (see pigeon_fota_update_available()) to
    decide whether a FOTA download is needed. This library does not
    read MCUboot's own embedded image version -- it trusts this
    build-time string, so bump it deliberately alongside whatever
    version string the corresponding image gets tagged with on the
    platform side (ideally from the same release pipeline), or the
    device will either loop re-downloading its own already-running
    image or never converge.

endif # PIGEON_FOTA

config PIGEON_WS
  bool "WebSocket push channel (persistent connection to <endpoint>/ws)"
  default n
  depends on PIGEON_CONNECTOR_HTTPS
  select WEBSOCKET_CLIENT
  select NET_CONTEXT_SNDTIMEO
  help
    Persistent wss:// connection to <CONFIG_PIGEON_ENDPOINT>/ws (dovecote's
    device WebSocket endpoint, task #32). Server pushes shadow_update frames
    on dashboard config writes so the device reacts without polling; the
    device sends application-level ping keepalives and (opportunistically)
    telemetry frames over the open socket. HTTPS remains the transport for
    shadow GET/report-back, log upload, and FOTA -- WS is push + telemetry
    only. Reuses CONFIG_PIGEON_ENDPOINT / CONFIG_PIGEON_TOKEN /
    CONFIG_PIGEON_HTTPS_SEC_TAG; no separate WS credentials exist.
    Zephyr's WEBSOCKET_CLIENT is marked EXPERIMENTAL upstream.
    NET_CONTEXT_SNDTIMEO is required for SO_SNDTIMEO (set on the WS socket
    in pigeon_ws_open_tls_socket()) to have any effect -- without it, every
    blocking send on this socket, including Zephyr's own internal CLOSE-frame
    echo, defaults to an unbounded wait (see that function's comment).

if PIGEON_WS

config PIGEON_WS_RX_BUF_SIZE
  int "WS receive/scratch buffer size (bytes)"
  default 1024
  help
    Sizes both websocket_request.tmp_buf (HTTP upgrade response + frame
    parse scratch, must outlive the connection) and the frame reassembly
    buffer a shadow_update must fit into. A shadow_update carries the full
    PigeonShadow with two escaped JSON-string configs; the HTTPS connector
    caps each decoded config at PIGEON_HTTPS_CONFIG_MAX (320), so 1024
    covers the framed/escaped equivalent. Server-side hard cap per frame
    is 16384 (dovecote MAX_WS_FRAME_BYTES); oversized inbound frames are
    drained and dropped with a warning, not fatal.

config PIGEON_WS_PING_INTERVAL_SEC
  int "Keepalive ping interval (seconds)"
  default 60
  help
    The server NEVER pings (dovecote objects/ws.rs: WsOutboundFrame::Ping
    is dead code); the device owns keepalive. Each interval sends
    {"type":"ping"} and expects {"type":"pong"}. Two consecutive missed
    pongs mark the connection half-open and force a reconnect. Budget:
    well under the server's 50-frames/10s limit.

config PIGEON_WS_RECONNECT_MAX_DELAY_SEC
  int "Reconnect backoff ceiling (seconds)"
  default 300

config PIGEON_WS_THREAD_STACK_SIZE
  int "WS worker thread stack size (bytes)"
  default 8192
  help
    The worker thread performs the TLS handshake (mbedTLS) itself; 8192
    matches wifi_init's TLS-proven CONFIG_MAIN_STACK_SIZE precedent.

endif # PIGEON_WS

endif # PIGEON

# Not nested under "if PIGEON": pigeon_core.c (which reads these) is compiled
# unconditionally by CMakeLists.txt regardless of CONFIG_PIGEON, so they must
# always have a value (an unsatisfied "if PIGEON" dependency would otherwise
# drop the CONFIG_PIGEON_* macro from autoconf.h entirely).
config PIGEON_ENDPOINT
  string "Pigeon Backend Endpoint"
  help
    URL of the PidgeIoT edge endpoint this device connects to: an
    https:// REST URL for CONFIG_PIGEON_CONNECTOR_HTTPS, or a
    coaps+tcp:// (RFC 8323 CoAP-over-TLS/TCP) host for
    CONFIG_PIGEON_CONNECTOR_COAP, since this device stack has no UDP
    support yet. Mirrors dovecote's build_http_endpoint output for HTTPS
    (e.g. https://api.pidgeiot.com/device/pigeons/<device_id>) and
    build_coap_endpoint's coaps+tcp:// output for CoAP -- though dovecote
    has no actual CoAP listener yet, only the endpoint string.

config PIGEON_TOKEN
  string "Pigeon Device Auth Token"
  help
    The opaque per-pigeon bearer credential issued by the backend (see
    dovecote's mint_device_credential/get_shadow_device -- a compact binary
    token verified against this pigeon's own stored public key, not a JWT),
    with no "Bearer " prefix -- the HTTPS connector adds that itself when
    building the Authorization header. Returned once at provisioning (or
    re-minted, invalidating the previous token, via a token/refresh call);
    override this per build (e.g. via a board/app Kconfig fragment) rather
    than committing a real token here.

config PIGEON_LOG_LEVEL
  int "Pigeon Library Log Level"
  default 3
  range 0 4
  help
    0: None, 1: Error, 2: Warning, 3: Info, 4: Debug

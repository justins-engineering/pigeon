{
  "files.associations": {
    "log-*.txt": "ansi",
    "*.conf": "kconfig"
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "./bootloader/**": true
  },
  "search.exclude": {
    "**/build": true
  },
  "python.defaultInterpreterPath": "${workspaceRoot}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "kconfig.zephyr.base": "${zephyrBase}",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build/https_init",
    "--query-driver=${env:HOME}/.local/zephyr-sdk-1.0.1/arm-zephyr-eabi/bin/*",
    "--completion-style=detailed",
    "--header-insertion=never",
    "--malloc-trim"
  ]
}
